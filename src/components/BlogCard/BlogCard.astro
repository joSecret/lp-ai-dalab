---
import './BlogCard.css';

interface Props {
  title: string;
  category: string;
  description: string;
  date: Date;
  slug: string;
  icon?: string;
}

const { title, category, description, date, slug, icon } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric'
});
---
<a href={`/blog/${slug}`} class="blog-card">
  <div class="blog-image">{icon ?? '📝'}</div>
  <div class="blog-content">
    <div class="blog-category">{category}</div>
    <h3 class="blog-title">{title}</h3>
    <p class="blog-excerpt">{description}</p>
    <div class="blog-meta">{formattedDate}</div>
  </div>
</a>
