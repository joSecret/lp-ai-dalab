---
import BaseLayout from '../../layouts/BaseLayout/BaseLayout.astro';
import Nav from '../../components/Nav/Nav.astro';
import Footer from '../../components/Footer/Footer.astro';
import { getCollection, render } from 'astro:content';
import navData from '../../data/navigation.json';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<BaseLayout title={`${post.data.title} — DALAB`} description={post.data.description}>
  <Nav links={navData.links} cta={navData.cta} />
  <main class="post-main">
    <div class="container">
      <div class="post-header">
        {post.data.icon && <div class="post-icon">{post.data.icon}</div>}
        <div class="post-category">{post.data.category}</div>
        <h1>{post.data.title}</h1>
        <div class="post-meta">{formattedDate}</div>
      </div>
      <div class="post-content">
        <Content />
      </div>
    </div>
  </main>
  <Footer footer={navData.footer} />
</BaseLayout>

<style>
  .post-main { padding-top: 72px; }
  .post-header {
    text-align: center;
    padding: 80px 0 60px;
    max-width: 700px;
    margin: 0 auto;
  }
  .post-icon { font-size: 64px; margin-bottom: 24px; }
  .post-category {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }
  h1 {
    font-family: var(--font-space-grotesk), sans-serif;
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    letter-spacing: -1.5px;
    margin-bottom: 16px;
  }
  .post-meta { font-size: 14px; color: var(--text-muted); }
  .post-content {
    max-width: 720px;
    margin: 0 auto;
    padding-bottom: 100px;
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-secondary);
  }
  .post-content h2 {
    font-family: var(--font-space-grotesk), sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 48px 0 16px;
    letter-spacing: -0.5px;
  }
  .post-content p { margin-bottom: 16px; }
  .post-content strong { color: var(--text-primary); font-weight: 600; }
  .post-content ul, .post-content ol { padding-left: 24px; margin-bottom: 16px; }
  .post-content li { margin-bottom: 8px; }
</style>
